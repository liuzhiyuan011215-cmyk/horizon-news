{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "mimo-v2.5-pro",
    "api_key_env": "OPENAI_API_KEY",
    "base_url": "https://token-plan-sgp.xiaomimimo.com/v1",
    "temperature": 0.3,
    "max_tokens": 512,
    "throttle_sec": 0
  },
  "languages": ["zh"],
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 3,
      "min_score": 500
    },
    "rss": [],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "fetch_comments": 0
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24,
    "enrichment_enabled": false
  },
  "webhook": {
    "enabled": true,
    "url_env": "TELEGRAM_WEBHOOK_URL",
    "delivery": "summary",
    "platform": "generic",
    "layout": "markdown",
    "request_body": {
      "chat_id": "6760290103",
      "text": "#{summary}",
      "parse_mode": "Markdown"
    }
  },
  "output": {
    "languages": ["zh"],
    "title": "每日科技新闻速递",
    "sections": [
      {
        "name": "🤖 科技新闻",
        "keywords": ["ai", "tech", "科技"]
      }
    ]
  }
}
